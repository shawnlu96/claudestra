DISCORD_BOT_TOKEN=your-bot-token
DISCORD_GUILD_ID=your-server-id
ALLOWED_USER_IDS=your-discord-user-id
BRIDGE_PORT=3847
CONTROL_CHANNEL_ID=your-control-channel-id
USER_NAME=Your Name
MCP_NAME=claudestra

# Optional overrides (leave commented — sensible defaults apply):
# BRIDGE_URL=ws://localhost:3847       # channel-server target; auto-derived from BRIDGE_PORT
# MASTER_DIR=/absolute/path/to/master  # master agent's cwd; defaults to <repo>/master

# Runtime-mutable toggles (managed via `bun src/manager.ts auto-update ...` → ~/.claude-orchestrator/config.json,
# NOT this file):
#   - Claudestra self-update    (default on, 30-min poll)
#   - Claude Code CLI update    (default on, weekly poll)
